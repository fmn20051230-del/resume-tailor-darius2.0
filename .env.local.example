# OpenRouter API key(s). One key, or comma- or newline-separated for multiple threads (each request picks one at random).
OPENROUTER_API_KEY=your_api_key_here

# Optional: IP whitelist. Comma-separated IPs; if set, only these IPs can access the app.
# ALLOWED_IPS=1.2.3.4,192.168.1.1

# Optional: default text for the Prompt textarea (shown when the page loads).
# Use NEXT_PUBLIC_ for tailoring prompt used by both manual and automation flows.
# Built-in default lives in lib/default-prompts.ts and config/tailoring-prompt.txt.
# NEXT_PUBLIC_DEFAULT_PROMPT=your custom tailoring prompt here

# Optional: tailoring prompt (server-side automation; falls back to file / built-in / NEXT_PUBLIC_DEFAULT_PROMPT)
# TAILORING_PROMPT=your custom tailoring prompt here

# Optional: JD extraction prompt for automation (or use config/extraction-prompt.txt / built-in)
# EXTRACTION_PROMPT=your extraction prompt here

# Optional: OpenRouter models
# EXTRACTION_MODEL=qwen/qwen3.5-flash-02-23
# TAILOR_MODEL=deepseek/deepseek-v4-flash

# Optional: automation output folder (default: output/)
# AUTOMATION_OUTPUT_DIR=output

# Optional: secret to view generation logs in the browser. If set, open /logs?key=<this_value>.
# LOG_VIEWER_SECRET=your_secret_here

# Optional: persistent logs on Vercel (survives cold starts). When you add Vercel KV / Upstash Redis
# in the Vercel dashboard, it sets KV_REST_API_URL and KV_REST_API_TOKEN automatically.
# Alternatively, create a DB at https://console.upstash.com and set:
# UPSTASH_REDIS_REST_URL=https://...
# UPSTASH_REDIS_REST_TOKEN=...

# Central log server (generation tracking dashboard)
LOG_SERVER_URL=https://resume-tailor-log-server.vercel.app
LOG_SERVER_API_KEY=fmn

# Optional: DOCX→PDF on Vercel / serverless (Word & LibreOffice are not available there).
# Get a secret at https://www.convertapi.com — without this, deployed ZIPs include DOCX only.
# CONVERTAPI_SECRET=your_convertapi_secret
